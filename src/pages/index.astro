---
import BaseLayout from "../layouts/BaseLayout.astro";
import ConnectMap from "../components/ConnectMap.astro";
import Header from "../components/Header.astro";
import ReviewsSection from "../components/ReviewsSection.astro";
import SiteFooter from "../components/SiteFooter.astro";
import {
  site,
  serviceGroups,
  teamGroups,
  policies,
  FULL_MENU_PATH,
  BOOKING_URL,
  formatCancellationPolicyText,
  teamMemberPath,
  socialDisplayHandle,
} from "../data/site";

type HoursGroup = { label: string; time: string };

type ValuesSeparatorKey = keyof typeof site.valuesSeparatorImages;

type ValuesItem =
  | { kind: "sep"; key: ValuesSeparatorKey }
  | { kind: "tag"; label: string };

function buildDesktopValuesItems(): ValuesItem[] {
  const items: ValuesItem[] = [
    { kind: "sep", key: site.valuesSeparatorsDesktop[0] },
  ];

  site.values.forEach((label, index) => {
    items.push({ kind: "tag", label });
    if (index < site.valuesSeparatorsDesktop.length - 1) {
      items.push({
        kind: "sep",
        key: site.valuesSeparatorsDesktop[index + 1],
      });
    }
  });

  return items;
}

function buildMobileValuesRowItems(
  row: (typeof site.valuesMobileRows)[number]
): ValuesItem[] {
  const items: ValuesItem[] = [];

  row.valueIndices.forEach((valueIndex, index) => {
    items.push({ kind: "sep", key: row.separators[index] });
    items.push({ kind: "tag", label: site.values[valueIndex] });
  });

  items.push({
    kind: "sep",
    key: row.separators[row.separators.length - 1],
  });

  return items;
}

const desktopValuesItems = buildDesktopValuesItems();
const mobileValuesRows = site.valuesMobileRows.map(buildMobileValuesRowItems);

type MobileValuesGridColumn =
  | { kind: "spacer" }
  | { kind: "content"; top: ValuesItem; bottom: ValuesItem };

function buildMobileValuesGridColumns(): MobileValuesGridColumn[] {
  const [row1, row2] = mobileValuesRows;
  const columns: MobileValuesGridColumn[] = [];

  row1.forEach((top, index) => {
    columns.push({ kind: "content", top, bottom: row2[index] });
    if (index < row1.length - 1) {
      columns.push({ kind: "spacer" });
    }
  });

  return columns;
}

const mobileValuesGridColumns = buildMobileValuesGridColumns();

function groupHours(
  hours: { day: string; time: string }[]
): HoursGroup[] {
  const open = hours.filter((entry) => entry.time !== "Closed");
  if (open.length === 0) return [];

  const groups: HoursGroup[] = [];
  let start = open[0].day;
  let end = open[0].day;
  let time = open[0].time;

  for (let i = 1; i < open.length; i++) {
    const entry = open[i];
    if (entry.time === time) {
      end = entry.day;
      continue;
    }

    groups.push({
      label: start === end ? start : `${start} – ${end}`,
      time,
    });
    start = entry.day;
    end = entry.day;
    time = entry.time;
  }

  groups.push({
    label: start === end ? start : `${start} – ${end}`,
    time,
  });

  return groups;
}

const hoursGroups = groupHours(site.hours);
const cancellationPolicy = policies.find(
  (policy) => policy.title === "CANCELLATION POLICY"
)!;
---

<BaseLayout>
  <Header />

  <main id="main">
    <section class="hero" aria-label="Salon Citrine in Irvington">
      <div class="hero__media">
        <div
          class="hero__slideshow"
          role="img"
          aria-label="Salon Citrine in historic Irvington: hero view, storefront exterior, and salon interior"
        >
          <img
            class="hero__image hero__image--slide"
            src="/images/background.png"
            alt=""
            width="1024"
            height="768"
            fetchpriority="high"
            aria-hidden="true"
          />
          <img
            class="hero__image hero__image--slide"
            src="/images/irvington-slideshow-1.png"
            alt=""
            width="819"
            height="1024"
            loading="lazy"
            aria-hidden="true"
          />
          <img
            class="hero__image hero__image--slide"
            src="/images/irvington-slideshow-2.png"
            alt=""
            width="1600"
            height="1200"
            loading="lazy"
            aria-hidden="true"
          />
        </div>
        <div class="hero__overlay" aria-hidden="true"></div>
        <h1 class="hero__title">Irvington</h1>
      </div>
    </section>

    <span id="about" class="scroll-target"></span>

    <section class="section" aria-labelledby="about-heading">
      <div class="section__inner intro">
        <div class="intro-split">
          <h2 class="section__title intro-split__tagline" id="about-heading">
            {site.tagline}
          </h2>
          <div class="intro__text intro-split__body">
            {site.about.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </div>
        <div class="intro__values">
          <div class="intro__values-row intro__values-row--desktop">
            {
              desktopValuesItems.map((item) => {
                if (item.kind === "sep") {
                  const isHat = item.key === "hat";
                  return (
                    <img
                      src={site.valuesSeparatorImages[item.key]}
                      alt=""
                      class:list={[
                        "intro__values-separator",
                        isHat && "intro__values-separator--hat",
                      ]}
                      width="14"
                      height="14"
                      loading="lazy"
                    />
                  );
                }

                return <span class="intro__values-tag">{item.label}</span>;
              })
            }
          </div>
          <div class="intro__values-grid intro__values-grid--mobile">
            {
              mobileValuesGridColumns.map((column) => {
                if (column.kind === "spacer") {
                  return (
                    <div
                      class="intro__values-spacer"
                      aria-hidden="true"
                    />
                  );
                }

                return (
                  <div class="intro__values-column">
                    {[column.top, column.bottom].map((item) => (
                      <div class="intro__values-cell">
                        {item.kind === "sep" ? (
                          <img
                            src={site.valuesSeparatorImages[item.key]}
                            alt=""
                            class:list={[
                              "intro__values-separator",
                              item.key === "hat" &&
                                "intro__values-separator--hat",
                            ]}
                            width="14"
                            height="14"
                            loading="lazy"
                          />
                        ) : (
                          <span class="intro__values-tag">{item.label}</span>
                        )}
                      </div>
                    ))}
                  </div>
                );
              })
            }
          </div>
        </div>
      </div>
      <figure class="about-image">
        <div
          class="about-image__slideshow"
          role="img"
          aria-label="Salon Citrine services slideshow: three collage portfolios of vivid hair color, creative cuts, and styling work from the Irvington salon"
        >
          <img
            class="about-image__photo about-image__photo--slide"
            src="/images/services-slideshow-1.png"
            alt=""
            width="1024"
            height="668"
            loading="lazy"
            aria-hidden="true"
          />
          <img
            class="about-image__photo about-image__photo--slide"
            src="/images/services-slideshow-2.png"
            alt=""
            width="1024"
            height="668"
            loading="lazy"
            aria-hidden="true"
          />
          <img
            class="about-image__photo about-image__photo--slide"
            src="/images/services-slideshow-3.png"
            alt=""
            width="1024"
            height="668"
            loading="lazy"
            aria-hidden="true"
          />
        </div>
        <div class="about-image__overlay" aria-hidden="true"></div>
        <p class="about-image__title" aria-hidden="true">Services</p>
      </figure>
    </section>

    <section class="section section--editorial" aria-labelledby="services-heading">
      <div class="section__inner section__inner--wide">
        <span id="services" class="scroll-target"></span>
        <aside class="services-cancellation" aria-label="Cancellation policy">
          <p class="services-cancellation__text">{formatCancellationPolicyText(cancellationPolicy.text)}</p>
        </aside>
        {
          serviceGroups.map((group) => (
            <div class="services-group">
              <header class="services-group__header">
                <h2
                  class="services-group__title"
                  id={group.id === "haircuts" ? "services-heading" : undefined}
                >
                  {group.title}
                </h2>
              </header>
              <div class="services-columns">
                {group.columns.map((column) => (
                  <div class="services-column">
                    <h3 class="services-column__header">{column.header}</h3>
                    {column.items?.map((item) => (
                      <article class="service-item">
                        <p class="service-item__name">{item.name}</p>
                        <p class="service-item__price">{item.price}</p>
                      </article>
                    ))}
                    {column.text && (
                      <p class="services-column__text">{column.text}</p>
                    )}
                  </div>
                ))}
              </div>
            </div>
          ))
        }
        <div class="services-cta">
          <a
            class="services-cta__link"
            href={FULL_MENU_PATH}
          >
            View Full Detailed Menu
          </a>
          <a
            class="services-cta__book"
            href={BOOKING_URL}
            target="_blank"
            rel="noopener noreferrer"
            data-booking-link
          >
            Book Now
          </a>
        </div>
      </div>
    </section>

    <section class="section" aria-labelledby="team-heading">
      <div class="section__inner section__inner--wide">
        <span id="team" class="scroll-target"></span>
        <header class="editorial-section__header">
          <h2 class="editorial-section__title" id="team-heading">team</h2>
        </header>
        {
          teamGroups.map((group) => (
            <div class="team-group">
              <h3 class="team-group__title">{group.title}</h3>
              <div class="team-grid">
                {group.members.map((member) => (
                  <article class="team-member">
                    <a
                      class="team-member__photo-link"
                      href={teamMemberPath(member.name)}
                      aria-label={`Open ${member.name} bio`}
                    >
                      <img
                        class="team-member__photo"
                        src={member.image}
                        alt={`${member.name}, ${member.role} at Salon Citrine`}
                        width="360"
                        height="480"
                        loading="lazy"
                      />
                      <span class="team-member__book-overlay">
                        Open Bio
                      </span>
                    </a>
                    <h4 class="team-member__name">{member.name}</h4>
                    <p class="team-member__role">{member.role}</p>
                  </article>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <section class="section section--editorial" aria-labelledby="policies-heading">
      <div class="section__inner section__inner--wide">
        <span id="policies" class="scroll-target"></span>
        <header class="editorial-section__header">
          <h2 class="editorial-section__title" id="policies-heading">policies</h2>
        </header>
        <div class="editorial-columns">
          {
            policies.map((policy) => (
              <article class="editorial-column">
                <h3 class="editorial-column__header">{policy.title}</h3>
                <p class="editorial-column__text">{policy.text}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <figure class="connect-image">
      <div
        class="connect-image__slideshow"
        role="img"
        aria-label="Salon Citrine team slideshow: owners seated together, stylists at work in the Irvington salon, and staff in creative costumes"
      >
        <img
          class="connect-image__photo connect-image__photo--slide"
          src="/images/about-team.png"
          alt=""
          width="1024"
          height="988"
          loading="lazy"
          aria-hidden="true"
        />
        <img
          class="connect-image__photo connect-image__photo--slide"
          src="/images/connect-slideshow-2.png"
          alt=""
          width="1024"
          height="988"
          loading="lazy"
          aria-hidden="true"
        />
        <img
          class="connect-image__photo connect-image__photo--slide"
          src="/images/connect-slideshow-3.png"
          alt=""
          width="1024"
          height="988"
          loading="lazy"
          aria-hidden="true"
        />
      </div>
      <div class="connect-image__overlay" aria-hidden="true"></div>
      <p class="connect-image__title" aria-hidden="true">Connect</p>
    </figure>

    <span id="connect" class="scroll-target"></span>

    <section class="connect-section" aria-labelledby="connect-heading">
      <h2 class="visually-hidden" id="connect-heading">Connect</h2>
      <div class="connect-split">
        <div class="connect-info">
          <div class="connect-info__layout">
            <div class="connect-info__logo">
              <img
                class="connect-info__logo-image connect-info__logo-image--light"
                src="/images/salon-citrine-logo-contact.png"
                alt={site.name}
                width="1000"
                height="1200"
                loading="lazy"
              />
              <img
                class="connect-info__logo-image connect-info__logo-image--dark"
                src="/images/salon-citrine-logo-dark.png"
                alt=""
                width="1000"
                height="1200"
                loading="lazy"
                aria-hidden="true"
              />
            </div>
            <div class="connect-info__content">
            <address class="connect-address">
              <a
                class="connect-address__link"
                href={site.address.mapsUrl}
                target="_blank"
                rel="noopener noreferrer"
              >
                {site.address.street}<br />
                {site.address.city}, {site.address.state} {site.address.zip}
              </a>
            </address>

            <div class="connect-hours" aria-label="Salon hours">
              {
                hoursGroups.map((group) => (
                  <p class="connect-hours__group">
                    <span class="connect-hours__days">{group.label}</span>
                    <span class="connect-hours__time">{group.time}</span>
                  </p>
                ))
              }
            </div>

            <div class="connect-contact">
              <a class="connect-contact__link" href={site.phoneHref}>
                {site.phone}
              </a>
              <a
                class="connect-contact__link"
                href={`mailto:${site.email}`}
              >
                {site.email}
              </a>
              <a
                class="connect-contact__link social-link"
                href={site.instagram}
                target="_blank"
                rel="noopener noreferrer"
              >
                <img
                  class="social-link__icon"
                  src="/icons/instagram.png"
                  alt=""
                  width="16"
                  height="16"
                  decoding="async"
                />
                {socialDisplayHandle(site.instagram)}
              </a>
            </div>
          </div>
          </div>
        </div>

        <ConnectMap />
      </div>
    </section>

    <div class="page-dark-zone">
      <span id="reviews" class="scroll-target"></span>
      <ReviewsSection />

      <SiteFooter />
    </div>
  </main>
</BaseLayout>
