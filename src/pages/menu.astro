---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import SiteFooter from "../components/SiteFooter.astro";
import MenuIntentCards from "../components/menu/MenuIntentCards.astro";
import MenuCategoryNav from "../components/menu/MenuCategoryNav.astro";
import MenuCategorySection from "../components/menu/MenuCategorySection.astro";
import MenuPricingNote from "../components/menu/MenuPricingNote.astro";
import { site, BOOKING_URL } from "../data/site";
import {
  MENU_INTRO_COPY,
  MENU_BOOKING_CTA,
  MENU_TOP_BOOKING_COPY,
  MENU_FOOTER_BOOKING_COPY,
} from "../data/menu-config";
import { buildVisitorMenuCategories } from "../data/menu";

const categories = buildVisitorMenuCategories();

const pageTitle = `Full Service Menu | ${site.name}`;
const pageDescription =
  "Explore Salon Citrine's full service menu for haircuts, dimensional color, blonding, vivid color, facials, waxing, and makeup with starting prices and online booking.";
---

<BaseLayout title={pageTitle} description={pageDescription} path="/menu/">
  <Header />

  <main id="main" class="menu-page">
    <section class="section section--editorial" aria-labelledby="menu-heading">
      <div class="section__inner section__inner--wide menu-page__inner">
        <header class="menu-page__header">
          <a class="menu-page__back" href="/#services">← Services overview</a>
          <h1 class="editorial-section__title" id="menu-heading">Full Service Menu</h1>
          <p class="menu-page__intro">{MENU_INTRO_COPY}</p>
        </header>

        <MenuPricingNote variant="top" />

        <aside class="menu-page__top-booking" data-menu-top-booking>
          <p class="menu-page__top-booking-copy">{MENU_TOP_BOOKING_COPY}</p>
          <a
            class="menu-page__book-cta"
            href={BOOKING_URL}
            target="_blank"
            rel="noopener noreferrer"
            data-booking-link
            data-analytics-action="menu-top-book"
          >
            {MENU_BOOKING_CTA}
          </a>
        </aside>

        <MenuIntentCards />

        <MenuCategoryNav categories={categories} />

        <div class="menu-page__categories" data-menu-categories>
          {categories.map((category) => (
            <MenuCategorySection category={category} />
          ))}
        </div>

        <MenuPricingNote variant="bottom" />

        <footer class="menu-page__footer" data-menu-footer-booking>
          <h2 class="menu-page__footer-title">Ready to book?</h2>
          <p class="menu-page__footer-copy">{MENU_FOOTER_BOOKING_COPY}</p>
          <a
            class="menu-page__book-cta menu-page__book-cta--large"
            href={BOOKING_URL}
            target="_blank"
            rel="noopener noreferrer"
            data-booking-link
            data-analytics-action="menu-footer-book"
          >
            {MENU_BOOKING_CTA}
          </a>
        </footer>
      </div>
    </section>
  </main>

  <SiteFooter />

  <script src="../scripts/menu-page.ts"></script>
</BaseLayout>
