---
import "../styles/global.css";
import BookingModal from "../components/BookingModal.astro";
import { site, BOOKING_URL, localBusinessJsonLd } from "../data/site";

const gaId = import.meta.env.PUBLIC_GA_ID;
const plausibleDomain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN;
const businessSchema = JSON.stringify(localBusinessJsonLd());

interface Props {
  title?: string;
  description?: string;
  path?: string;
  ogImage?: string;
  /** Overrides the fixed bottom book bar link (e.g. per-stylist GlossGenius URL). */
  bookBarUrl?: string;
}

const {
  title = `${site.name} | Hair Salon in Indianapolis, IN`,
  description = site.tagline,
  path = "/",
  ogImage = "/images/background.png",
  bookBarUrl,
} = Astro.props;

const resolvedBookBarUrl = bookBarUrl ?? BOOKING_URL;

const canonicalUrl = `https://${site.domain}${path}`;
const ogImageUrl = `https://${site.domain}${ogImage}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <script type="application/ld+json" set:html={businessSchema} />
    {
      gaId && (
        <>
          <script
            async
            src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}
          />
          <script is:inline define:vars={{ gaId }}>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
              dataLayer.push(arguments);
            }
            gtag("js", new Date());
            gtag("config", gaId);
          </script>
        </>
      )
    }
    {
      !gaId && plausibleDomain && (
        <script
          defer
          data-domain={plausibleDomain}
          src="https://plausible.io/js/script.js"
        />
      )
    }
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <title>{title}</title>
    <script is:inline>
      (function () {
        var storageKey = "theme";
        var desktopMq = window.matchMedia("(min-width: 1101px)");
        var prefersDarkMq = window.matchMedia("(prefers-color-scheme: dark)");
        var theme;

        if (desktopMq.matches) {
          theme = prefersDarkMq.matches ? "dark" : "light";
        } else {
          var stored = localStorage.getItem(storageKey);
          theme =
            stored === "dark" || stored === "light"
              ? stored
              : prefersDarkMq.matches
                ? "dark"
                : "light";
        }

        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to Content</a>
    <slot />
    <BookingModal />
    <aside class="book-bar">
      <a
        class="book-bar__link"
        href={resolvedBookBarUrl}
        target="_blank"
        rel="noopener noreferrer"
        data-booking-link
      >
        Book Now
      </a>
    </aside>
    <script>
      const desktopMq = window.matchMedia("(min-width: 1101px)");
      const prefersDarkMq = window.matchMedia("(prefers-color-scheme: dark)");
      const mobileThemeToggle = document.querySelector<HTMLButtonElement>(
        ".site-header__theme-toggle--mobile[data-theme-toggle]",
      );
      const storageKey = "theme";

      function systemTheme(): "light" | "dark" {
        return prefersDarkMq.matches ? "dark" : "light";
      }

      function getStoredTheme(): "light" | "dark" | null {
        const stored = localStorage.getItem(storageKey);
        return stored === "dark" || stored === "light" ? stored : null;
      }

      function resolveTheme(): "light" | "dark" {
        if (desktopMq.matches) {
          return systemTheme();
        }
        return getStoredTheme() ?? systemTheme();
      }

      function updateToggleLabels(theme: "light" | "dark") {
        const label =
          theme === "dark" ? "Switch to light mode" : "Switch to dark mode";
        mobileThemeToggle?.setAttribute("aria-label", label);
      }

      function applyTheme(theme: "light" | "dark") {
        document.documentElement.setAttribute("data-theme", theme);
        updateToggleLabels(theme);
      }

      function syncTheme() {
        applyTheme(resolveTheme());
      }

      syncTheme();

      mobileThemeToggle?.addEventListener("click", () => {
        const current =
          document.documentElement.getAttribute("data-theme") === "dark"
            ? "dark"
            : "light";
        const next = current === "dark" ? "light" : "dark";
        localStorage.setItem(storageKey, next);
        applyTheme(next);
      });

      desktopMq.addEventListener("change", syncTheme);

      prefersDarkMq.addEventListener("change", () => {
        if (desktopMq.matches || !getStoredTheme()) {
          syncTheme();
        }
      });

      const menuToggle = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
      const nav = document.querySelector<HTMLElement>("[data-mobile-nav]");
      const dropdowns = document.querySelectorAll<HTMLElement>("[data-nav-dropdown]");

      function closeDropdown(dropdown: HTMLElement) {
        const trigger = dropdown.querySelector<HTMLButtonElement>("[data-dropdown-trigger]");
        dropdown.classList.remove("is-open");
        trigger?.setAttribute("aria-expanded", "false");
      }

      function openDropdown(dropdown: HTMLElement) {
        const trigger = dropdown.querySelector<HTMLButtonElement>("[data-dropdown-trigger]");
        dropdown.classList.add("is-open");
        trigger?.setAttribute("aria-expanded", "true");
      }

      function setDropdownOpen(dropdown: HTMLElement, open: boolean) {
        if (open) {
          openDropdown(dropdown);
        } else {
          closeDropdown(dropdown);
        }
      }

      dropdowns.forEach((dropdown) => {
        const trigger = dropdown.querySelector<HTMLButtonElement>("[data-dropdown-trigger]");
        const menu = dropdown.querySelector<HTMLElement>("[data-dropdown-menu]");
        const items = menu
          ? Array.from(menu.querySelectorAll<HTMLAnchorElement>("a[role='menuitem']"))
          : [];

        trigger?.addEventListener("click", (event) => {
          event.stopPropagation();
          const isOpen = dropdown.classList.contains("is-open");

          dropdowns.forEach((other) => {
            if (other !== dropdown) {
              closeDropdown(other);
            }
          });

          setDropdownOpen(dropdown, !isOpen);
        });

        trigger?.addEventListener("keydown", (event) => {
          if (event.key === "ArrowDown") {
            event.preventDefault();
            dropdowns.forEach((other) => {
              if (other !== dropdown) {
                closeDropdown(other);
              }
            });
            openDropdown(dropdown);
            items[0]?.focus();
          }

          if (event.key === "Escape") {
            closeDropdown(dropdown);
          }
        });

        menu?.addEventListener("keydown", (event) => {
          const activeItem = document.activeElement;
          const currentIndex = items.findIndex((item) => item === activeItem);

          if (event.key === "ArrowDown") {
            event.preventDefault();
            items[Math.min(currentIndex + 1, items.length - 1)]?.focus();
          }

          if (event.key === "ArrowUp") {
            event.preventDefault();
            if (currentIndex <= 0) {
              closeDropdown(dropdown);
              trigger?.focus();
            } else {
              items[currentIndex - 1]?.focus();
            }
          }

          if (event.key === "Escape") {
            event.preventDefault();
            closeDropdown(dropdown);
            trigger?.focus();
          }

          if (event.key === "Tab" && !event.shiftKey && currentIndex === items.length - 1) {
            closeDropdown(dropdown);
          }
        });

      });

      document.addEventListener("click", (event) => {
        dropdowns.forEach((dropdown) => {
          if (!dropdown.contains(event.target as Node)) {
            closeDropdown(dropdown);
          }
        });
      });

      function closeMobileMenu() {
        nav?.classList.remove("is-open");
        menuToggle?.setAttribute("aria-expanded", "false");
        dropdowns.forEach((dropdown) => closeDropdown(dropdown));
      }

      menuToggle?.addEventListener("click", () => {
        const isOpen = nav?.classList.toggle("is-open");
        menuToggle.setAttribute("aria-expanded", String(!!isOpen));

        if (!isOpen) {
          dropdowns.forEach((dropdown) => closeDropdown(dropdown));
        }
      });

      document
        .querySelector<HTMLButtonElement>("[data-menu-close]")
        ?.addEventListener("click", closeMobileMenu);

      nav?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", closeMobileMenu);
      });
    </script>
  </body>
</html>
