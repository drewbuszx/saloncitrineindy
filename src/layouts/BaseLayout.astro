---
import "../styles/global.css";
import BookingModal from "../components/BookingModal.astro";
import { site, BOOKING_URL, localBusinessJsonLd } from "../data/site";

const gaId = import.meta.env.PUBLIC_GA_ID;
const plausibleDomain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN;
const businessSchema = JSON.stringify(localBusinessJsonLd());

interface Props {
  title?: string;
  description?: string;
  path?: string;
  ogImage?: string;
  /** Preload the LCP hero image on this page. */
  preloadImage?: string;
  /** Overrides the fixed bottom book bar link (e.g. per-stylist GlossGenius URL). */
  bookBarUrl?: string;
  /** Stylist slug for the book bar (e.g. andra-kramer triggers the existing-client gate). */
  bookBarStylistSlug?: string;
}

const GOOGLE_FONTS_URL =
  "https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Oswald:wght@400;500;600;700&display=swap";

const {
  title = `${site.name} | Hair Salon in Indianapolis, IN`,
  description = site.tagline,
  path = "/",
  ogImage = "/images/background.png",
  preloadImage,
  bookBarUrl,
  bookBarStylistSlug,
} = Astro.props;

const resolvedBookBarUrl = bookBarUrl ?? BOOKING_URL;

const canonicalUrl = `https://${site.domain}${path}`;
const ogImageUrl = `https://${site.domain}${ogImage}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    {/* ?v=2 busts sticky browser favicon cache after switching from crystal → SC logo */}
    <link rel="icon" href="/favicon.ico?v=2" sizes="48x48" />
    <link rel="icon" type="image/png" sizes="any" href="/favicon.png?v=2" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=2" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href={GOOGLE_FONTS_URL} />
    <link
      rel="preload"
      href="/fonts/BasicTitle.ttf"
      as="font"
      type="font/ttf"
      crossorigin
    />
    {
      preloadImage && (
        <link
          rel="preload"
          as="image"
          href={preloadImage}
          fetchpriority="high"
        />
      )
    }
    <script type="application/ld+json" set:html={businessSchema} />
    {
      gaId && (
        <>
          <script
            async
            src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}
          />
          <script is:inline define:vars={{ gaId }}>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
              dataLayer.push(arguments);
            }
            gtag("js", new Date());
            gtag("config", gaId);
          </script>
        </>
      )
    }
    {
      !gaId && plausibleDomain && (
        <script
          defer
          data-domain={plausibleDomain}
          src="https://plausible.io/js/script.js"
        />
      )
    }
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <title>{title}</title>
    <script is:inline>
      (function () {
        var storageKey = "theme";
        var desktopMq = window.matchMedia("(min-width: 1101px)");
        var prefersDarkMq = window.matchMedia("(prefers-color-scheme: dark)");
        var theme;

        if (desktopMq.matches) {
          theme = prefersDarkMq.matches ? "dark" : "light";
        } else {
          var stored = localStorage.getItem(storageKey);
          theme =
            stored === "dark" || stored === "light"
              ? stored
              : prefersDarkMq.matches
                ? "dark"
                : "light";
        }

        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to Content</a>
    <slot />
    <BookingModal />
    <aside class="book-bar">
      <a
        class="book-bar__link"
        href={resolvedBookBarUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Book an appointment at ${site.name} (opens in new tab)`}
        data-booking-link
        data-booking-stylist={bookBarStylistSlug}
      >
        Book Now
      </a>
    </aside>
    <script>
      const desktopMq = window.matchMedia("(min-width: 1101px)");
      const prefersDarkMq = window.matchMedia("(prefers-color-scheme: dark)");
      const mobileThemeToggle = document.querySelector<HTMLButtonElement>(
        ".site-header__theme-toggle--mobile[data-theme-toggle]",
      );
      const storageKey = "theme";

      function systemTheme(): "light" | "dark" {
        return prefersDarkMq.matches ? "dark" : "light";
      }

      function getStoredTheme(): "light" | "dark" | null {
        const stored = localStorage.getItem(storageKey);
        return stored === "dark" || stored === "light" ? stored : null;
      }

      function resolveTheme(): "light" | "dark" {
        if (desktopMq.matches) {
          return systemTheme();
        }
        return getStoredTheme() ?? systemTheme();
      }

      function updateToggleLabels(theme: "light" | "dark") {
        const label =
          theme === "dark" ? "Switch to light mode" : "Switch to dark mode";
        mobileThemeToggle?.setAttribute("aria-label", label);
      }

      function applyTheme(theme: "light" | "dark") {
        document.documentElement.setAttribute("data-theme", theme);
        updateToggleLabels(theme);
      }

      function syncTheme() {
        applyTheme(resolveTheme());
      }

      syncTheme();

      mobileThemeToggle?.addEventListener("click", () => {
        const current =
          document.documentElement.getAttribute("data-theme") === "dark"
            ? "dark"
            : "light";
        const next = current === "dark" ? "light" : "dark";
        localStorage.setItem(storageKey, next);
        applyTheme(next);
      });

      desktopMq.addEventListener("change", syncTheme);

      prefersDarkMq.addEventListener("change", () => {
        if (desktopMq.matches || !getStoredTheme()) {
          syncTheme();
        }
      });

      const menuToggle = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
      const menuClose = document.querySelector<HTMLButtonElement>("[data-menu-close]");
      const nav = document.querySelector<HTMLElement>("[data-mobile-nav]");
      const dropdowns = document.querySelectorAll<HTMLElement>("[data-nav-dropdown]");
      const mobileFocusableSelector =
        'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])';

      function getMobileNavFocusables() {
        if (!nav) return [];
        return Array.from(nav.querySelectorAll<HTMLElement>(mobileFocusableSelector));
      }

      function setMobileNavAccessible(hidden: boolean) {
        nav?.setAttribute("aria-hidden", String(hidden));

        getMobileNavFocusables().forEach((element) => {
          if (hidden) {
            if (!element.hasAttribute("data-tabindex-restore")) {
              const tabindex = element.getAttribute("tabindex");
              element.setAttribute(
                "data-tabindex-restore",
                tabindex === null ? "" : tabindex,
              );
            }
            element.setAttribute("tabindex", "-1");
            return;
          }

          const restore = element.getAttribute("data-tabindex-restore");
          if (restore === null) return;

          if (restore === "") {
            element.removeAttribute("tabindex");
          } else {
            element.setAttribute("tabindex", restore);
          }
          element.removeAttribute("data-tabindex-restore");
        });
      }

      function handleMobileMenuKeydown(event: KeyboardEvent) {
        if (!nav?.classList.contains("is-open")) {
          return;
        }

        if (event.key === "Escape") {
          event.preventDefault();
          closeMobileMenu();
          return;
        }

        if (event.key !== "Tab") {
          return;
        }

        const focusable = getMobileNavFocusables().filter(
          (element) => element.tabIndex !== -1,
        );
        if (focusable.length === 0) {
          event.preventDefault();
          return;
        }

        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        const active = document.activeElement;

        if (event.shiftKey && active === first) {
          event.preventDefault();
          last.focus();
        } else if (!event.shiftKey && active === last) {
          event.preventDefault();
          first.focus();
        }
      }

      setMobileNavAccessible(true);

      function closeDropdown(dropdown: HTMLElement) {
        const trigger = dropdown.querySelector<HTMLButtonElement>("[data-dropdown-trigger]");
        dropdown.classList.remove("is-open");
        trigger?.setAttribute("aria-expanded", "false");
      }

      function openDropdown(dropdown: HTMLElement) {
        const trigger = dropdown.querySelector<HTMLButtonElement>("[data-dropdown-trigger]");
        dropdown.classList.add("is-open");
        trigger?.setAttribute("aria-expanded", "true");
      }

      function setDropdownOpen(dropdown: HTMLElement, open: boolean) {
        if (open) {
          openDropdown(dropdown);
        } else {
          closeDropdown(dropdown);
        }
      }

      dropdowns.forEach((dropdown) => {
        const trigger = dropdown.querySelector<HTMLButtonElement>("[data-dropdown-trigger]");
        const menu = dropdown.querySelector<HTMLElement>("[data-dropdown-menu]");
        const items = menu
          ? Array.from(menu.querySelectorAll<HTMLAnchorElement>("a[role='menuitem']"))
          : [];

        trigger?.addEventListener("click", (event) => {
          event.stopPropagation();
          const isOpen = dropdown.classList.contains("is-open");

          dropdowns.forEach((other) => {
            if (other !== dropdown) {
              closeDropdown(other);
            }
          });

          setDropdownOpen(dropdown, !isOpen);
        });

        if (desktopMq.matches) {
          dropdown.addEventListener("mouseenter", () => {
            dropdowns.forEach((other) => {
              if (other !== dropdown) {
                closeDropdown(other);
              }
            });
            openDropdown(dropdown);
          });

          dropdown.addEventListener("mouseleave", () => {
            closeDropdown(dropdown);
          });
        }

        trigger?.addEventListener("keydown", (event) => {
          if (event.key === "ArrowDown") {
            event.preventDefault();
            dropdowns.forEach((other) => {
              if (other !== dropdown) {
                closeDropdown(other);
              }
            });
            openDropdown(dropdown);
            items[0]?.focus();
          }

          if (event.key === "Escape") {
            closeDropdown(dropdown);
          }
        });

        menu?.addEventListener("keydown", (event) => {
          const activeItem = document.activeElement;
          const currentIndex = items.findIndex((item) => item === activeItem);

          if (event.key === "ArrowDown") {
            event.preventDefault();
            items[Math.min(currentIndex + 1, items.length - 1)]?.focus();
          }

          if (event.key === "ArrowUp") {
            event.preventDefault();
            if (currentIndex <= 0) {
              closeDropdown(dropdown);
              trigger?.focus();
            } else {
              items[currentIndex - 1]?.focus();
            }
          }

          if (event.key === "Escape") {
            event.preventDefault();
            closeDropdown(dropdown);
            trigger?.focus();
          }

          if (event.key === "Tab" && !event.shiftKey && currentIndex === items.length - 1) {
            closeDropdown(dropdown);
          }
        });

      });

      document.addEventListener("click", (event) => {
        dropdowns.forEach((dropdown) => {
          if (!dropdown.contains(event.target as Node)) {
            closeDropdown(dropdown);
          }
        });
      });

      function setMobileMenuOpen(open: boolean) {
        nav?.classList.toggle("is-open", open);
        menuToggle?.setAttribute("aria-expanded", String(open));
        menuToggle?.setAttribute("aria-label", open ? "Close menu" : "Open menu");
        document.body.classList.toggle("mobile-menu-open", open);
        setMobileNavAccessible(!open);

        if (open) {
          document.addEventListener("keydown", handleMobileMenuKeydown);
          const firstFocusable = getMobileNavFocusables().find(
            (element) => element.tabIndex !== -1,
          );
          firstFocusable?.focus();
        } else {
          document.removeEventListener("keydown", handleMobileMenuKeydown);
          dropdowns.forEach((dropdown) => closeDropdown(dropdown));
        }
      }

      function closeMobileMenu() {
        const wasOpen = nav?.classList.contains("is-open");
        setMobileMenuOpen(false);
        if (wasOpen) {
          menuToggle?.focus();
        }
      }

      menuToggle?.addEventListener("click", () => {
        const isOpen = !nav?.classList.contains("is-open");
        setMobileMenuOpen(isOpen);
      });

      menuClose?.addEventListener("click", closeMobileMenu);

      nav?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", closeMobileMenu);
      });
    </script>
  </body>
</html>
