---
import type { MenuService } from "../../data/menu";
import {
  MENU_CONSULTATIONS_ANCHOR,
  MENU_CONSULTATION_REQUIRED_CTA,
  MENU_CONSULTATION_REQUIRED_NOTE_BODY,
  MENU_CONSULTATION_REQUIRED_NOTE_LEAD,
} from "../../data/menu-config";

interface Props {
  service: MenuService;
  presentation?: "full" | "compact";
}

const { service, presentation = service.presentation } = Astro.props;
const isCompact = presentation === "compact";
const metaParts = [service.priceDisplay, service.durationDisplay].filter(Boolean);

/** Consultation services are informational only — no per-row booking. */
const showConsultationRequiredNote =
  !service.isAddon && service.requiresConsultation && !service.isConsultation;
---

<article
  class:list={[
    "menu-service",
    isCompact ? "menu-service--compact" : "menu-service--full",
    showConsultationRequiredNote && "menu-service--actionable",
  ]}
  data-menu-service-card
  id={service.anchorId}
>
  <div class="menu-service__header">
    <h3 class="menu-service__name">{service.name}</h3>
    {
      service.labels.length > 0 && (
        <ul class="menu-service__labels" aria-label="Service notes">
          {service.labels.map((label) => (
            <li class="menu-service__label">{label}</li>
          ))}
        </ul>
      )
    }
  </div>

  {
    metaParts.length > 0 && (
      <p class="menu-service__meta">
        {metaParts.join(" · ")}
      </p>
    )
  }

  {
    service.descriptionBody && (
      <p class="menu-service__description">{service.descriptionBody}</p>
    )
  }

  {
    service.qualifier && (
      <p class="menu-service__qualifier">{service.qualifier}</p>
    )
  }

  {
    showConsultationRequiredNote && (
      <div class="menu-service__consult-note">
        <p class="menu-service__consult-copy">
          <strong>{MENU_CONSULTATION_REQUIRED_NOTE_LEAD}</strong>
          {" "}
          {MENU_CONSULTATION_REQUIRED_NOTE_BODY}
        </p>
        <a
          class="menu-service__consult"
          href={`#${MENU_CONSULTATIONS_ANCHOR}`}
          data-menu-intent-link={MENU_CONSULTATIONS_ANCHOR}
          data-analytics-action="consultation-required-cta"
          data-analytics-service={service.name}
        >
          {MENU_CONSULTATION_REQUIRED_CTA}
        </a>
      </div>
    )
  }
</article>
