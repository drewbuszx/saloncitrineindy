---
import type { MenuService } from "../../data/menu";
import { MENU_CONSULTATION_CTA } from "../../data/menu-config";

interface Props {
  service: MenuService;
}

const { service } = Astro.props;
const metaParts = [service.priceDisplay, service.durationDisplay].filter(Boolean);

/** Only consultation-specific actions stay on cards — not per-service "Book This Service". */
const showConsultationCta =
  !service.isAddon && (service.isConsultation || service.requiresConsultation);

const consultationHref = service.isConsultation
  ? service.bookingUrl
  : "#consultations";

const consultationIsBookingLink = service.isConsultation;
---

<article
  class:list={[
    "menu-service-card",
    showConsultationCta && "menu-service-card--actionable",
  ]}
  data-menu-service-card
>
  <div class="menu-service-card__header">
    <h3 class="menu-service-card__name">{service.name}</h3>
    {
      service.labels.length > 0 && (
        <ul class="menu-service-card__labels" aria-label="Service notes">
          {service.labels.map((label) => (
            <li class="menu-service-card__label">{label}</li>
          ))}
        </ul>
      )
    }
  </div>

  {
    metaParts.length > 0 && (
      <p class="menu-service-card__meta">
        {metaParts.join(" · ")}
      </p>
    )
  }

  {
    service.descriptionBody && (
      <p class="menu-service-card__description">{service.descriptionBody}</p>
    )
  }

  {
    service.qualifier && (
      <p class="menu-service-card__qualifier">{service.qualifier}</p>
    )
  }

  {
    showConsultationCta && (
      <a
        class="menu-service-card__consult"
        href={consultationHref}
        {...(consultationIsBookingLink
          ? {
              target: "_blank",
              rel: "noopener noreferrer",
              "data-booking-link": true,
            }
          : {
              "data-menu-intent-link": "consultations",
            })}
        data-analytics-action={
          service.isConsultation ? "consultation-service-book" : "consultation-required-cta"
        }
        data-analytics-service={service.name}
      >
        {MENU_CONSULTATION_CTA}
      </a>
    )
  }
</article>
