---
import { site } from "../data/site";

const addressLine = `${site.address.street}, ${site.address.city}, ${site.address.state} ${site.address.zip}`;
---

<div class="connect-map">
  <div
    class="connect-map__viewport"
    id="connect-map"
    data-lat={site.address.lat}
    data-lng={site.address.lng}
    data-name={site.name}
    data-address={addressLine}
    data-phone={site.phone}
    data-phone-href={site.phoneHref}
    data-maps-url={site.address.mapsUrl}
    role="region"
    aria-label={`Interactive map showing ${site.name} at ${addressLine}`}
  >
  </div>
  <p class="connect-map__attribution">
    <a
      href="https://www.openstreetmap.org/copyright"
      target="_blank"
      rel="noopener noreferrer"
    >
      © OpenStreetMap contributors
    </a>
  </p>
</div>

<script>
  /** Matches connect mobile layout breakpoint in global.css */
  const CONNECT_MAP_MOBILE_QUERY = "(max-width: 768px)";

  function isConnectMapMobileViewport() {
    return window.matchMedia(CONNECT_MAP_MOBILE_QUERY).matches;
  }

  function getConnectMapOptions(isMobile: boolean) {
    return {
      scrollWheelZoom: false,
      zoomControl: false,
      attributionControl: false,
      dragging: !isMobile,
      touchZoom: !isMobile,
      doubleClickZoom: !isMobile,
      boxZoom: !isMobile,
      keyboard: !isMobile,
      tap: true,
      tapHold: false,
    };
  }

  function applyConnectMapInteractionMode(
    map: import("leaflet").Map,
    isMobile: boolean
  ) {
    const handlers = [
      map.dragging,
      map.touchZoom,
      map.doubleClickZoom,
      map.boxZoom,
      map.keyboard,
    ] as const;

    for (const handler of handlers) {
      if (isMobile) {
        handler.disable();
      } else {
        handler.enable();
      }
    }
  }

  async function initConnectMap() {
    const container = document.getElementById("connect-map");
    if (!container || container.dataset.mapReady === "true") return;

    const lat = Number(container.dataset.lat);
    const lng = Number(container.dataset.lng);
    const name = container.dataset.name ?? "";
    const address = container.dataset.address ?? "";
    const phone = container.dataset.phone ?? "";
    const phoneHref = container.dataset.phoneHref ?? "";
    const mapsUrl = container.dataset.mapsUrl ?? "";

    if (!Number.isFinite(lat) || !Number.isFinite(lng)) return;

    const [{ default: L }] = await Promise.all([
      import("leaflet"),
      import("leaflet/dist/leaflet.css"),
    ]);

    const isMobile = isConnectMapMobileViewport();

    const map = L.map(container, {
      center: [lat, lng],
      zoom: 15,
      ...getConnectMapOptions(isMobile),
    });

    L.control
      .zoom({
        position: "bottomright",
        zoomInTitle: "Zoom in",
        zoomOutTitle: "Zoom out",
      })
      .addTo(map);

    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      maxZoom: 19,
    }).addTo(map);

    const markerIcon = L.divIcon({
      className: "connect-map__marker-icon",
      html: `<svg class="connect-map__marker-svg" viewBox="-2 -1 28 36" aria-hidden="true" focusable="false"><path d="M12 0C5.373 0 0 5.373 0 12c0 8.25 12 20 12 20s12-11.75 12-20C24 5.373 18.627 0 12 0z" fill="var(--color-citrine)" stroke="#000" stroke-width="1.5"></path></svg>`,
      iconSize: [26, 34],
      iconAnchor: [13, 34],
      popupAnchor: [0, -36],
    });

    const marker = L.marker([lat, lng], { icon: markerIcon }).addTo(map);

    marker.bindPopup(
      `<div class="connect-map__popup">
        <p class="connect-map__popup-name">${name}</p>
        <p class="connect-map__popup-address">${address}</p>
        <div class="connect-map__popup-actions">
          <a class="connect-map__popup-action" href="${phoneHref}">Call ${phone}</a>
          <a class="connect-map__popup-action" href="${mapsUrl}" target="_blank" rel="noopener noreferrer">Directions</a>
        </div>
      </div>`,
      {
        closeButton: true,
        className: "connect-map__popup-wrapper",
        minWidth: 210,
        maxWidth: 260,
      }
    );

    const refreshMapSize = () => {
      map.invalidateSize({ pan: false });
    };

    container.dataset.mapReady = "true";
    container.dataset.mapMobile = isMobile ? "true" : "false";

    map.whenReady(refreshMapSize);
    requestAnimationFrame(() => {
      refreshMapSize();
      requestAnimationFrame(refreshMapSize);
    });
    window.addEventListener("load", refreshMapSize, { once: true });

    const resizeTarget = container.closest(".connect-map") ?? container;
    if ("ResizeObserver" in window) {
      const resizeObserver = new ResizeObserver(() => {
        refreshMapSize();
      });
      resizeObserver.observe(resizeTarget);
    }

    const mobileMedia = window.matchMedia(CONNECT_MAP_MOBILE_QUERY);
    const syncInteractionMode = () => {
      const nextIsMobile = mobileMedia.matches;
      container.dataset.mapMobile = nextIsMobile ? "true" : "false";
      applyConnectMapInteractionMode(map, nextIsMobile);
      refreshMapSize();
    };

    if ("addEventListener" in mobileMedia) {
      mobileMedia.addEventListener("change", syncInteractionMode);
    } else {
      mobileMedia.addListener(syncInteractionMode);
    }
  }

  function observeConnectMap() {
    const container = document.getElementById("connect-map");
    if (!container || container.dataset.mapObserved === "true") return;

    container.dataset.mapObserved = "true";

    if (!("IntersectionObserver" in window)) {
      void initConnectMap();
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        if (!entries.some((entry) => entry.isIntersecting)) return;
        observer.disconnect();
        void initConnectMap();
      },
      { rootMargin: "240px" }
    );

    observer.observe(container);
  }

  observeConnectMap();
  document.addEventListener("astro:page-load", observeConnectMap);
</script>
