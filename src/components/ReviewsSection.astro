---
import reviewsData from "../data/reviews.json";

export type Review = {
  name: string;
  rating: number | null;
  text: string;
  stylist?: string;
};

const EXCLUDED_STYLISTS = ["Haley Clayton", "Caitlin Bondi"];

function isExcludedStylist(stylist: string | undefined) {
  if (!stylist) return false;
  const normalized = stylist.toLowerCase().trim();
  return EXCLUDED_STYLISTS.some((name) => {
    const lower = name.toLowerCase();
    if (normalized.includes(lower)) return true;
    const [first, last] = lower.split(/\s+/);
    return Boolean(first && last && normalized.includes(first) && normalized.includes(last));
  });
}

const reviews = (reviewsData as Review[])
  .filter((review) => review.text)
  .filter((review) => !isExcludedStylist(review.stylist));

function stars(rating: number | null) {
  if (!rating) return null;
  return "★".repeat(rating) + "☆".repeat(Math.max(0, 5 - rating));
}
---

<section class="reviews-section" aria-labelledby="reviews-heading">
  <div class="reviews-section__inner">
    <header class="reviews-section__header">
      <h2 class="reviews-section__title" id="reviews-heading">reviews</h2>
    </header>

    <div
      class="reviews-carousel"
      data-reviews-carousel
      aria-roledescription="carousel"
      aria-label="Client reviews"
    >
      <div class="reviews-carousel__controls">
        <button
          class="reviews-carousel__btn reviews-carousel__btn--prev"
          type="button"
          aria-label="Previous reviews"
          data-reviews-prev
        >
          <svg viewBox="0 0 12 12" aria-hidden="true">
            <path d="M7.5 2.5 4 6l3.5 3.5" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </button>
        <button
          class="reviews-carousel__btn reviews-carousel__btn--next"
          type="button"
          aria-label="Next reviews"
          data-reviews-next
        >
          <svg viewBox="0 0 12 12" aria-hidden="true">
            <path d="M4.5 2.5 8 6l-3.5 3.5" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </button>
      </div>

      <div
        class="reviews-carousel__viewport"
        id="reviews-carousel-viewport"
        aria-live="polite"
        aria-atomic="true"
      >
        <div class="reviews-carousel__track" data-reviews-track>
          {
            reviews.map((review) => (
              <article class="review-card" data-review-card>
                {review.rating && (
                  <p class="review-card__rating" aria-label={`${review.rating} out of 5 stars`}>
                    <span aria-hidden="true">{stars(review.rating)}</span>
                  </p>
                )}
                <blockquote class="review-card__quote">
                  <p>{review.text}</p>
                </blockquote>
                <footer class="review-card__footer">
                  <cite class="review-card__name">{review.name}</cite>
                  {review.stylist && (
                    <p class="review-card__stylist">with {review.stylist}</p>
                  )}
                </footer>
              </article>
            ))
          }
        </div>
      </div>

      <div class="reviews-carousel__footer" data-reviews-footer hidden>
        <div class="reviews-carousel__dots" data-reviews-dots role="tablist" aria-label="Review pages"></div>
      </div>
    </div>
  </div>
</section>

<script>
  function initReviewsCarousel(root: HTMLElement) {
    const cards = Array.from(
      root.querySelectorAll<HTMLElement>("[data-review-card]")
    );
    const track = root.querySelector<HTMLElement>("[data-reviews-track]");
    const prevBtn = root.querySelector<HTMLButtonElement>("[data-reviews-prev]");
    const nextBtn = root.querySelector<HTMLButtonElement>("[data-reviews-next]");
    const dotsContainer = root.querySelector<HTMLElement>("[data-reviews-dots]");
    const footer = root.querySelector<HTMLElement>("[data-reviews-footer]");
    if (!track || cards.length === 0) return;

    let currentPage = 0;
    let cardsPerPage = 1;
    let lastPageCount = 0;
    let timer: ReturnType<typeof setInterval> | undefined;
    let dotButtons: HTMLButtonElement[] = [];
    const autoplayMs = 6000;
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    function getCardsPerPage() {
      const width = root.clientWidth;
      if (width >= 1024) return Math.min(3, cards.length);
      if (width >= 640) return Math.min(2, cards.length);
      return 1;
    }

    function getPageCount() {
      return Math.max(1, Math.ceil(cards.length / cardsPerPage));
    }

    function renderDots() {
      if (!dotsContainer || !footer) return;
      const pageCount = getPageCount();

      if (pageCount <= 1) {
        footer.hidden = true;
        dotButtons = [];
        dotsContainer.replaceChildren();
        lastPageCount = pageCount;
        return;
      }

      footer.hidden = false;

      if (pageCount !== lastPageCount) {
        dotsContainer.replaceChildren();
        dotButtons = Array.from({ length: pageCount }, (_, index) => {
          const button = document.createElement("button");
          button.type = "button";
          button.className = "reviews-carousel__dot";
          button.setAttribute("role", "tab");
          button.setAttribute("aria-controls", "reviews-carousel-viewport");
          button.setAttribute("aria-label", `Go to review page ${index + 1} of ${pageCount}`);
          button.addEventListener("click", () => {
            goToPage(index);
            startAutoplay();
          });
          return button;
        });

        dotButtons.forEach((button) => dotsContainer.appendChild(button));
        lastPageCount = pageCount;
      }

      updateDots();
    }

    function updateDots() {
      dotButtons.forEach((button, index) => {
        const isActive = index === currentPage;
        button.classList.toggle("is-active", isActive);
        button.setAttribute("aria-selected", isActive ? "true" : "false");
      });

      const activeDot = dotButtons[currentPage];
      if (activeDot) {
        activeDot.classList.remove("is-active");
        void activeDot.offsetWidth;
        activeDot.classList.add("is-active");
      }
    }

    function layoutCards() {
      const gap = 24;
      const viewportWidth = root.clientWidth;
      cardsPerPage = getCardsPerPage();
      const pageCount = getPageCount();

      if (currentPage >= pageCount) {
        currentPage = 0;
      }

      const cardWidth =
        cardsPerPage === 1
          ? Math.min(viewportWidth, 420)
          : (viewportWidth - gap * (cardsPerPage - 1)) / cardsPerPage;

      track.style.setProperty("--review-card-width", `${cardWidth}px`);
      track.style.setProperty("--review-gap", `${gap}px`);
    track.style.width = `${pageCount * viewportWidth}px`;
    track.style.maxWidth = `${pageCount * viewportWidth}px`;

      cards.forEach((card, index) => {
        const page = Math.floor(index / cardsPerPage);
        const indexInPage = index % cardsPerPage;
        const visibleInPage = Math.min(
          cardsPerPage,
          cards.length - page * cardsPerPage
        );
        const groupWidth =
          visibleInPage * cardWidth + gap * Math.max(0, visibleInPage - 1);
        const offsetWithinPage =
          (viewportWidth - groupWidth) / 2 + indexInPage * (cardWidth + gap);

        card.style.width = `${cardWidth}px`;
        card.style.left = `${page * viewportWidth + offsetWithinPage}px`;
        card.setAttribute(
          "aria-hidden",
          page === currentPage ? "false" : "true",
        );
      });

      track.style.transform = `translateX(${-currentPage * viewportWidth}px)`;

      const pageStart = currentPage * cardsPerPage;
      const pageEnd = Math.min(pageStart + cardsPerPage, cards.length);
      let maxHeight = 0;
      for (let i = pageStart; i < pageEnd; i++) {
        maxHeight = Math.max(maxHeight, cards[i].offsetHeight);
      }
      track.style.height = `${Math.max(maxHeight, 192)}px`;

      renderDots();
    }

    function goToPage(page: number) {
      currentPage = page;
      layoutCards();
      updateDots();
    }

    function nextPage() {
      goToPage((currentPage + 1) % getPageCount());
    }

    function prevPage() {
      goToPage((currentPage - 1 + getPageCount()) % getPageCount());
    }

    function startAutoplay() {
      if (timer) clearInterval(timer);
      if (getPageCount() <= 1 || reducedMotion) return;
      timer = setInterval(nextPage, autoplayMs);
    }

    function stopAutoplay() {
      if (timer) clearInterval(timer);
      timer = undefined;
    }

    layoutCards();
    startAutoplay();

    prevBtn?.addEventListener("click", () => {
      prevPage();
      startAutoplay();
    });

    nextBtn?.addEventListener("click", () => {
      nextPage();
      startAutoplay();
    });

    root.addEventListener("keydown", (event) => {
      if (event.key === "ArrowLeft") {
        event.preventDefault();
        prevPage();
        startAutoplay();
      }

      if (event.key === "ArrowRight") {
        event.preventDefault();
        nextPage();
        startAutoplay();
      }
    });

    root.addEventListener("mouseenter", stopAutoplay);
    root.addEventListener("mouseleave", startAutoplay);
    root.addEventListener("focusin", stopAutoplay);
    root.addEventListener("focusout", (event) => {
      if (!root.contains(event.relatedTarget as Node)) {
        startAutoplay();
      }
    });

    const resizeObserver = new ResizeObserver(() => {
      layoutCards();
      startAutoplay();
    });
    resizeObserver.observe(root);

    if (reducedMotion) {
      stopAutoplay();
      goToPage(0);
    }
  }

  document.querySelectorAll<HTMLElement>("[data-reviews-carousel]").forEach(initReviewsCarousel);
</script>
